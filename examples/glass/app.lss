@tokens {
    ink: #ffffffff;
    sub: #e7ecffcc;
    chip-ink: #f4f7ffff;
}

/* The frosted panel: a translucent white tint over a blurred, slightly more
   vivid backdrop. The blur is what makes it read as glass; refraction + specular
   add the "Liquid Glass" edge lensing and a top-left rim highlight. */
.glass {
    background: #ffffff26;
    border-radius: 28px;
    border: 1px #ffffff66;
    backdrop-filter: blur(18px) saturate(140%) refraction(14px) specular(0.6);
}
.title { color: $ink; }
.subtitle { color: $sub; }

.chip {
    background: #ffffff33;
    border-radius: 999px;
    color: $chip-ink;
    backdrop-filter: blur(8px) refraction(6px) specular(0.5);
}
