@tokens {
    page: #0b0f1aff;
    surface: #141a28ff;
    ink: #eef2fbff;
    muted: #8893abff;
    accent: #4f8cff;
    field: #0e1422ff;
    ok: #38d39f;
}

#page { background: $page; }
#card { background: $surface; border-radius: 22px; }
.title { color: $ink; }
.subtitle { color: $muted; }

.row { background: $field; border-radius: 12px; }
.label { color: $muted; }
.value { color: $ink; }
.badge { background: $field; color: $ok; border-radius: 999px; }
.loading { color: $accent; }

.btn { background: $accent; color: #ffffffff; border-radius: 12px; }
